# Copie ce fichier en ".env" et renseigne tes vraies clés.
# Ne jamais committer le fichier ".env" (avec les vraies clés) sur GitHub.

# ── API ANTHROPIC (génération des comptes-rendus) ─────────────────────────────
# Obtenir sur https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-ta-vraie-cle-ici

# ── API ASSEMBLYAI (transcription audio) ──────────────────────────────────────
# Obtenir sur https://www.assemblyai.com → Account → API Key
ASSEMBLYAI_API_KEY=ta-cle-assemblyai-ici

# ── BASE DE DONNÉES (historique des CR) ───────────────────────────────────────
# PostgreSQL — ex. Neon (https://neon.tech), Railway, Supabase…
# Format : postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── SERVEUR ───────────────────────────────────────────────────────────────────
PORT=3000

# ── AUTHENTIFICATION ──────────────────────────────────────────────────────────
# Mot de passe pour accéder à l'outil (laisser vide = pas de protection)
# Utilise un mot de passe fort : min. 12 caractères, majuscules + chiffres + symboles
ACCESS_PASSWORD=ton-mot-de-passe-fort-ici

# Clé secrète pour signer le cookie de session — ne pas changer après déploiement
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=genere-une-cle-aleatoire-de-64-caracteres-hex
